# Không copy những file này vào Docker image
# Lý do: giảm context size, tăng security

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/

# Virtual environment
venv/
env/
.venv/

# IDE
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db

# Secrets — QUAN TRỌNG: không bao giờ đưa .env vào image
.env
.env.*
!.env.example

# Git
.git/
.gitignore

# Docs và test
*.md
tests/
docs/

# Node.js (for frontend)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Frontend build artifacts
src/dist/
src/build/

# Logs
*.log

# Temporary files
.tmp/
temp/